        <script><![CDATA[// 1. CLIENT-SIDE: This runs the moment the button is clicked
function confirmCancel() {
    // Pop up the confirmation box
    var answer = confirm("Are you sure you want to cancel this loan request? This action cannot be undone.");

    // If the user clicks "OK"
    if (answer == true) {
        // gsftSubmit sends the action back to the server. 
        // IMPORTANT: The third parameter MUST perfectly match your 'Action name'
        gsftSubmit(null, g_form.getFormElement(), 'cancel_loan_request');
    } else {
        // If they click "Cancel", stop everything
        return false;
    }
}

// 2. SERVER-SIDE: This runs only after gsftSubmit is called above. Indicates that we are not on the client side anymore.
if (typeof window == 'undefined') {
    executeCancellation();
}

function executeCancellation() {
    // Update the state to the backend value for Cancelled
    current.state = 12;
    current.update();

    // Refresh the page and show a success message
    gs.addInfoMessage("Your loaner request has been successfully cancelled.");
    action.setRedirectURL(current);
}]]></script>
